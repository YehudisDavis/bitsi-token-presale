generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

model User {
  id        String    @id @default(cuid())
  wallet    String    @unique
  createdAt DateTime  @default(now())
  vouchers  Voucher[]
}

model Voucher {
  id              String        @id @default(cuid())
  wallet          String
  amountPaid      Float
  buyingPower     Float
  discountPercent Int
  status          VoucherStatus @default(ACTIVE)
  nonce           String        @unique @default(cuid())
  createdAt       DateTime      @default(now())
  redeemedAt      DateTime?
  user            User          @relation(fields: [wallet], references: [wallet])
}
