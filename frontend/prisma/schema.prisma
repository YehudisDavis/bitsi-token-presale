generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

model User {
  id        String    @id @default(cuid())
  wallet    String    @unique
  createdAt DateTime  @default(now())
  vouchers  Voucher[]
}

model Voucher {
  id              String        @id @default(cuid())
  wallet          String
  amountPaid      Float
  buyingPower     Float
  discountPercent Int
  status          VoucherStatus @default(ACTIVE)
  nonce           String        @unique @default(cuid())
  createdAt       DateTime      @default(now())
  redeemedAt      DateTime?
  user            User          @relation(fields: [wallet], references: [wallet])
}

enum TemplateState {
  ACTIVE
  INACTIVE
  SOLD_OUT
}

model VoucherTemplate {
  id             String        @id @default(cuid())
  voucherId      Int           @unique @default(autoincrement())
  voucherType    Int           @unique
  amount         Float
  maxPurchase    Float
  participation  Int
  ethPrice       String
  validationDate DateTime
  state          TemplateState @default(ACTIVE)
  createdAt      DateTime      @default(now())
}
